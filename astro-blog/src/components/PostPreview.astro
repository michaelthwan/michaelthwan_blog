---
import type { CollectionEntry } from 'astro:content';

interface Props {
    post: CollectionEntry<'posts'>;
    formatDate: (dateStr: string) => string;
    featured?: boolean;
    categoryLabel?: string;
}

const { post, formatDate, featured = false, categoryLabel } = Astro.props;
const primaryTag = post.data.tags?.[0];
---

<article class:list={['post-preview', { 'post-featured': featured }]}>
    <a href={`/posts/${post.slug}`} class="post-link">
        <div class="post-thumbnail">
            {post.data.thumbnail ? (
                <img src={post.data.thumbnail} alt="" />
            ) : (
                <div class="thumbnail-fallback" aria-hidden="true">
                    <span>Article</span>
                </div>
            )}
        </div>
        <div class="post-content">
            <div class="post-meta">
                {featured && <span class="post-kicker">Latest{categoryLabel && ` · ${categoryLabel}`}</span>}
                <span class="post-date">{formatDate(post.data.published)}</span>
                {!featured && primaryTag && <span class="post-tag-label">{primaryTag}</span>}
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-abstract">{post.data.abstract}</p>
            <p class="post-authors">
                {post.data.authors.slice(0, 3).map((author, i) => (
                    <Fragment>
                        <span set:html={author.replace(' ', '&nbsp;')} />
                        {i < Math.min(post.data.authors.length, 3) - 1 && ', '}
                    </Fragment>
                ))}
                {post.data.authors.length > 3 && <em>, et&nbsp;al.</em>}
            </p>
        </div>
    </a>
</article>
